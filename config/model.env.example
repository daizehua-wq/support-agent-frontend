# 模型提供方式：local / api / hybrid
MODEL_PROVIDER=local

# 模型运行模式：strict-local / local-first / api-only
MODEL_MODE=strict-local

HOST=0.0.0.0
PORT=3001

# 本地模型配置
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=deepseek-r1:14b
# 本地大模型超时建议保留较长时间，避免首次生成超时
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_TIMEOUT_MS=180000

# API 模型配置（默认关闭）
API_LLM_BASE_URL=
API_LLM_MODEL=
API_LLM_API_KEY=
API_LLM_TIMEOUT_MS=30000

# 安全相关
ALLOW_API_SENSITIVE_DATA=false
ALLOW_API_MODEL=false
ALLOW_INTERNET_SUPPLEMENT=false
ALLOW_RAW_CONVERSATION_EXPORT=false
