# 企业实网回归专用参数（MySQL / PostgreSQL）
# 使用方式：
# 1) cp config/database-enterprise.env.example config/database-enterprise.env
# 2) 填入真实企业库参数
# 3) npm run test:db:enterprise

API_BASE_URL=http://127.0.0.1:3001
DB_ENTERPRISE_REQUIRE_ALL=false
DB_ENTERPRISE_SKIP_MYSQL=false
DB_ENTERPRISE_SKIP_POSTGRES=false

# -------- MySQL --------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_NAME=sales_support_agent_mysql
MYSQL_ID=enterprise-mysql
MYSQL_ENVIRONMENT=enterprise
MYSQL_DESCRIPTION=enterprise mysql validation
MYSQL_ACCOUNT_ID=enterprise-mysql-account
MYSQL_ADMIN_USERNAME=
MYSQL_ADMIN_PASSWORD=

# -------- PostgreSQL --------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=
POSTGRES_NAME=sales_support_agent_pg
POSTGRES_ID=enterprise-postgres
POSTGRES_ENVIRONMENT=enterprise
POSTGRES_DESCRIPTION=enterprise postgres validation
POSTGRES_ACCOUNT_ID=enterprise-postgres-account
POSTGRES_ADMIN_USERNAME=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_DATABASE=postgres
POSTGRES_MAINTENANCE_DATABASE=postgres
