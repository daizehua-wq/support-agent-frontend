{
  "name": "sales-support-agent-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:mock": "node mock-server/server.js",
    "dev:py-runtime": "python3 -m uvicorn python_runtime.app.main:app --host 0.0.0.0 --port 8008 --reload",
    "dev:all": "node scripts/dev-all.mjs",
    "stack:up": "node scripts/local-stack.mjs up",
    "stack:verify": "node scripts/local-stack.mjs verify",
    "stack:down": "node scripts/local-stack.mjs down",
    "stack:run": "node scripts/local-stack.mjs run",
    "desktop:dev": "electron electron/main.js",
    "desktop:build": "npm run desktop:pack",
    "desktop:pack": "VITE_API_BASE_URL=http://127.0.0.1:3001 VITE_PLATFORM_MANAGER_BASE_URL=http://127.0.0.1:3003 npm run build && electron-builder --config electron-builder.config.cjs --mac dir",
    "desktop:dist": "VITE_API_BASE_URL=http://127.0.0.1:3001 VITE_PLATFORM_MANAGER_BASE_URL=http://127.0.0.1:3003 npm run build && electron-builder --config electron-builder.config.cjs --mac",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "type-check": "tsc -b --pretty false",
    "preview": "vite preview",
    "test:db:api": "node scripts/database-api-integration.mjs",
    "test:db:enterprise": "node scripts/database-enterprise-regression.mjs",
    "test:settings:governance": "node scripts/settings-governance-regression.mjs",
    "test:release": "npm run test:workflow:release",
    "test:fix4": "node scripts/phase1-fix4-regression.mjs",
    "test:fix4:e2e": "node scripts/run-fix4-e2e.mjs",
    "test:fix4:all": "npm run test:fix4 && npm run test:fix4:e2e",
    "test:fix4:verify": "npm run verify:frontend && node scripts/run-fix4-api-mainchain.mjs && npm run test:fix4:e2e",
    "verify:frontend": "npm run lint && npm run type-check && npm run build",
    "test:workflow:release": "node scripts/workflow-release-regression.mjs",
    "test:workflow:matrix": "node scripts/workflow-platform-regression.mjs",
    "test:external:real-smoke": "node scripts/real-external-api-smoke.mjs",
    "benchmark:embedded-model": "node scripts/benchmark-embedded-model.mjs",
    "check:p4": "npm --prefix api-gateway run check",
    "check:p5": "npm --prefix platform-manager run check",
    "ops:supervisor": "node scripts/prod-supervisor.mjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-jaeger": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "antd": "^6.3.4",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mysql2": "^3.22.0",
    "node-llama-cpp": "^3.18.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "redis": "^5.12.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
