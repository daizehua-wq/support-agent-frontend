{
  "specVersion": "plugin-spec/v1",
  "pluginId": "industry.output.healthcare-compliance",
  "displayName": "Output Healthcare Compliance",
  "description": "行业插件：输出完成后注入医疗行业合规提醒节点。",
  "kind": "output",
  "route": "generate-script",
  "enabled": true,
  "defaultPlugin": false,
  "order": 30,
  "workflow": {
    "specVersion": "workflow-node-spec/v1",
    "entryNodeId": "output-main",
    "nodes": [
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "output-main",
        "type": "output.script.v1",
        "module": "output",
        "operation": "generateScript",
        "inputMode": "request",
        "timeoutMs": 45000,
        "retryPolicy": {
          "maxRetries": 1,
          "backoffMs": 200
        },
        "connectorRefs": [
          "evidence"
        ],
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.retry",
          "workflow.node.complete",
          "workflow.node.error"
        ]
      },
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "output-compliance-shield",
        "type": "custom.output.compliance-shield.v1",
        "module": "output",
        "operation": "applyComplianceShield",
        "inputMode": "previous-node",
        "dependsOn": [
          "output-main"
        ],
        "condition": {
          "path": "request.industryType",
          "exists": true
        },
        "timeoutMs": 8000,
        "retryPolicy": {
          "maxRetries": 1,
          "backoffMs": 100
        },
        "continueOnError": true,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.retry",
          "workflow.node.complete",
          "workflow.node.error"
        ],
        "handler": {
          "modulePath": "plugins/nodes/industryWorkflowNodes.js",
          "exportName": "runOutputComplianceShield"
        },
        "inputOverrides": {
          "policyTag": "healthcare-safe"
        }
      }
    ]
  },
  "connectors": [
    {
      "specVersion": "connector-spec/v1",
      "id": "evidence",
      "connectorType": "session-evidence",
      "adapterType": "session-evidence",
      "required": false,
      "settingsPath": "trace.sessionEvidences",
      "whitelistKeys": [],
      "limitsKeys": [],
      "capabilities": [
        "reference-summary"
      ]
    }
  ],
  "eventSchema": {
    "specVersion": "event-schema/v1",
    "eventTypes": [
      "plugin.execution.start",
      "workflow.node.start",
      "workflow.node.retry",
      "workflow.node.complete",
      "workflow.node.error",
      "plugin.execution.complete",
      "plugin.execution.error"
    ],
    "requiredFields": [
      "eventId",
      "eventType",
      "occurredAt",
      "pluginId",
      "route",
      "nodeId"
    ]
  },
  "traceSchema": {
    "specVersion": "trace-schema/v1",
    "requiredSections": [
      "plugin",
      "workflow",
      "events",
      "timing",
      "result"
    ],
    "compatibility": [
      "executionContext",
      "traceSummary"
    ]
  },
  "outputBinding": {
    "nodeId": "output-compliance-shield",
    "path": "$"
  }
}
