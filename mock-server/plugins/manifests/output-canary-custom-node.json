{
  "specVersion": "plugin-spec/v1",
  "pluginId": "custom.output.canary-annotator",
  "displayName": "Output Canary Annotator",
  "description": "灰度插件：在标准输出后追加一个自定义节点，用于验证可插拔编排与回滚能力。",
  "kind": "output",
  "route": "generate-script",
  "enabled": true,
  "defaultPlugin": false,
  "order": 15,
  "release": {
    "specVersion": "plugin-release-spec/v1",
    "stage": "canary",
    "trafficPercent": 20,
    "stablePluginId": "builtin.output.default",
    "rollbackOnError": true,
    "bucketBy": "sessionId"
  },
  "workflow": {
    "specVersion": "workflow-node-spec/v1",
    "entryNodeId": "output-main",
    "nodes": [
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "output-main",
        "type": "output.script.v1",
        "module": "output",
        "operation": "generateScript",
        "inputMode": "request",
        "timeoutMs": 45000,
        "retryPolicy": {
          "maxRetries": 1,
          "backoffMs": 200
        },
        "connectorRefs": [
          "evidence"
        ],
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.retry",
          "workflow.node.complete",
          "workflow.node.error"
        ]
      },
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "output-canary-annotate",
        "type": "custom.output.annotate.v1",
        "module": "output",
        "operation": "annotateScript",
        "inputMode": "previous-node",
        "dependsOn": [
          "output-main"
        ],
        "timeoutMs": 8000,
        "retryPolicy": {
          "maxRetries": 1,
          "backoffMs": 100
        },
        "connectorRefs": [
          "evidence"
        ],
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.retry",
          "workflow.node.complete",
          "workflow.node.error"
        ],
        "handler": {
          "modulePath": "plugins/nodes/outputCanaryAnnotatorNode.js",
          "exportName": "runOutputCanaryAnnotator"
        },
        "inputOverrides": {
          "releaseTag": "output-canary-v1",
          "appendNotice": "[canary] custom workflow node executed",
          "failureFlagKey": "forceCanaryNodeFailure",
          "metadataKey": "customWorkflowNodeMeta"
        }
      }
    ]
  },
  "connectors": [
    {
      "specVersion": "connector-spec/v1",
      "id": "evidence",
      "connectorType": "session-evidence",
      "adapterType": "session-evidence",
      "required": false,
      "settingsPath": "trace.sessionEvidences",
      "whitelistKeys": [],
      "limitsKeys": [],
      "capabilities": [
        "reference-summary"
      ]
    }
  ],
  "eventSchema": {
    "specVersion": "event-schema/v1",
    "eventTypes": [
      "plugin.execution.start",
      "workflow.node.start",
      "workflow.node.retry",
      "workflow.node.complete",
      "workflow.node.error",
      "plugin.execution.complete",
      "plugin.execution.error",
      "plugin.rollback.start",
      "plugin.rollback.complete",
      "plugin.rollback.error"
    ],
    "requiredFields": [
      "eventId",
      "eventType",
      "occurredAt",
      "pluginId",
      "route",
      "nodeId"
    ]
  },
  "traceSchema": {
    "specVersion": "trace-schema/v1",
    "requiredSections": [
      "plugin",
      "workflow",
      "events",
      "timing",
      "result"
    ],
    "compatibility": [
      "executionContext",
      "traceSummary",
      "rollback"
    ]
  },
  "outputBinding": {
    "nodeId": "output-canary-annotate",
    "path": "$"
  }
}
