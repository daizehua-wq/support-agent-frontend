# 模型提供方式：local / api / hybrid
MODEL_PROVIDER=local

# 模型运行模式：strict-local / local-first / api-only
MODEL_MODE=strict-local

HOST=0.0.0.0
PORT=3001

# Redis 会话缓存
REDIS_URL=redis://127.0.0.1:6379

# OpenTelemetry tracing
# 可选：console / jaeger / otlp
OTEL_TRACES_EXPORTER=console
OTEL_SERVICE_NAME=mock-server
# OTLP HTTP 示例（例如接 OpenTelemetry Collector 或 Jaeger OTLP）
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=authorization=replace-with-token
# Jaeger HTTP Collector 示例
# OTEL_TRACES_EXPORTER=jaeger
# OTEL_EXPORTER_JAEGER_ENDPOINT=http://127.0.0.1:14268/api/traces

# 本地模型配置
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=deepseek-r1:14b
# 本地大模型整体超时。本地模型首次启动可调高，CI/门禁/无模型环境建议 < 30s。
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_TIMEOUT_MS=8000

# API 模型配置（默认关闭）
API_LLM_BASE_URL=
API_LLM_MODEL=
API_LLM_API_KEY=
OPENAI_API_KEY=
API_LLM_TIMEOUT_MS=30000

# 安全相关
ALLOW_API_SENSITIVE_DATA=false
ALLOW_API_MODEL=false
ALLOW_INTERNET_SUPPLEMENT=false
ALLOW_RAW_CONVERSATION_EXPORT=false

# ===== 安全合规（SSO / 密钥托管）=====
# Settings 密钥托管主密钥（建议 32+ 长度）
SETTINGS_SECRET_MASTER_KEY=replace-with-local-secret

# 外部资料 provider（仅放本地真实值，样例保持空）
QICHACHA_API_KEY=

# HashiCorp Vault 预留（当前 provider 抽象已就位，后续可接）
SETTINGS_HASHICORP_VAULT_ADDR=
SETTINGS_HASHICORP_VAULT_TOKEN=
SETTINGS_HASHICORP_VAULT_NAMESPACE=

# Cloud KMS 预留（当前 provider 抽象已就位，后续可接）
SETTINGS_CLOUD_KMS_CREDENTIALS=
SETTINGS_CLOUD_KMS_KEY_ID=
SETTINGS_CLOUD_KMS_REGION=

# 企业 SSO JWT（mode=jwt-hs256 时生效）
SETTINGS_SSO_JWT_SECRET=

# ===== 运维告警与成本阈值 =====
OPS_ALERT_MIN_SAMPLE_SIZE=20
OPS_ALERT_MAX_ERROR_RATE_PERCENT=25
OPS_ALERT_CONSECUTIVE_FAILURES=3
OPS_ALERT_DAILY_COST_USD_THRESHOLD=20
OPS_PY_RUNTIME_FAILURE_THRESHOLD=2

# 成本估算参数（USD / 1K tokens）
OPS_CLOUD_PROMPT_USD_PER_1K=0.0005
OPS_CLOUD_COMPLETION_USD_PER_1K=0.0015
OPS_LOCAL_PROMPT_USD_PER_1K=0
OPS_LOCAL_COMPLETION_USD_PER_1K=0

# 进程守护事件上报保护（可选）
OPS_EVENT_TOKEN=
