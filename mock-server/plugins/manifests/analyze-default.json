{
  "specVersion": "plugin-spec/v1",
  "pluginId": "builtin.analyze.default",
  "displayName": "Analyze Default",
  "description": "默认客户分析插件，执行标准分析节点。",
  "kind": "analyze",
  "route": "analyze-customer",
  "enabled": true,
  "defaultPlugin": true,
  "order": 10,
  "workflow": {
    "specVersion": "workflow-node-spec/v1",
    "entryNodeId": "analyze-main",
    "nodes": [
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "analyze-main",
        "type": "analyze.customer.v1",
        "module": "analyze",
        "operation": "analyzeCustomer",
        "inputMode": "request",
        "timeoutMs": 45000,
        "retryPolicy": {
          "maxRetries": 1,
          "backoffMs": 200
        },
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.retry",
          "workflow.node.complete",
          "workflow.node.error"
        ]
      }
    ]
  },
  "connectors": [
    {
      "specVersion": "connector-spec/v1",
      "id": "assistant-context",
      "connectorType": "assistant-context",
      "adapterType": "assistant-context",
      "required": false,
      "settingsPath": "settings.assistant.executionContext",
      "whitelistKeys": [],
      "limitsKeys": [],
      "capabilities": [
        "assistant-scope"
      ]
    }
  ],
  "eventSchema": {
    "specVersion": "event-schema/v1",
    "eventTypes": [
      "plugin.execution.start",
      "workflow.node.start",
      "workflow.node.retry",
      "workflow.node.complete",
      "workflow.node.error",
      "plugin.execution.complete",
      "plugin.execution.error"
    ],
    "requiredFields": [
      "eventId",
      "eventType",
      "occurredAt",
      "pluginId",
      "route",
      "nodeId"
    ]
  },
  "traceSchema": {
    "specVersion": "trace-schema/v1",
    "requiredSections": [
      "plugin",
      "workflow",
      "events",
      "timing",
      "result"
    ],
    "compatibility": [
      "executionContext",
      "modelRuntimeSummary"
    ]
  },
  "outputBinding": {
    "nodeId": "analyze-main",
    "path": "$"
  }
}
