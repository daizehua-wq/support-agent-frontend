{
  "specVersion": "plugin-spec/v1",
  "pluginId": "builtin.output.concise-first",
  "displayName": "Output Concise First",
  "description": "示例插件：仅通过 manifest 固定输出语气为 concise。",
  "kind": "output",
  "route": "generate-script",
  "enabled": true,
  "defaultPlugin": false,
  "order": 20,
  "workflow": {
    "specVersion": "workflow-node-spec/v1",
    "entryNodeId": "output-main",
    "nodes": [
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "output-main",
        "type": "output.script.v1",
        "module": "output",
        "operation": "generateScript",
        "inputMode": "request",
        "timeoutMs": 45000,
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.complete"
        ],
        "inputOverrides": {
          "toneStyle": "concise"
        }
      }
    ]
  },
  "connectors": [
    {
      "specVersion": "connector-spec/v1",
      "id": "evidence",
      "connectorType": "session-evidence",
      "adapterType": "session-evidence",
      "required": false,
      "settingsPath": "trace.sessionEvidences",
      "whitelistKeys": [],
      "limitsKeys": [],
      "capabilities": [
        "reference-summary"
      ]
    }
  ],
  "eventSchema": {
    "specVersion": "event-schema/v1",
    "eventTypes": [
      "plugin.execution.start",
      "workflow.node.start",
      "workflow.node.complete",
      "plugin.execution.complete",
      "plugin.execution.error"
    ],
    "requiredFields": [
      "eventId",
      "eventType",
      "occurredAt",
      "pluginId",
      "route",
      "nodeId"
    ]
  },
  "traceSchema": {
    "specVersion": "trace-schema/v1",
    "requiredSections": [
      "plugin",
      "workflow",
      "events",
      "timing",
      "result"
    ],
    "compatibility": [
      "executionContext",
      "traceSummary"
    ]
  },
  "outputBinding": {
    "nodeId": "output-main",
    "path": "$"
  }
}
