{
  "specVersion": "plugin-spec/v1",
  "pluginId": "builtin.search.external-first",
  "displayName": "Search External First",
  "description": "示例插件：仅通过 manifest 把检索策略改为优先启用外部补充。",
  "kind": "search",
  "route": "search-documents",
  "enabled": true,
  "defaultPlugin": false,
  "order": 20,
  "workflow": {
    "specVersion": "workflow-node-spec/v1",
    "entryNodeId": "search-main",
    "nodes": [
      {
        "specVersion": "workflow-node-spec/v1",
        "id": "search-main",
        "type": "search.documents.v1",
        "module": "search",
        "operation": "searchDocuments",
        "inputMode": "request",
        "timeoutMs": 45000,
        "continueOnError": false,
        "emitEvents": [
          "workflow.node.start",
          "workflow.node.complete"
        ],
        "inputOverrides": {
          "enableExternalSupplement": true
        }
      }
    ]
  },
  "connectors": [
    {
      "specVersion": "connector-spec/v1",
      "id": "knowledge",
      "connectorType": "knowledge",
      "adapterType": "knowledge",
      "required": false,
      "settingsPath": "settings.search.connectors.knowledge[]",
      "whitelistKeys": [
        "docTypes",
        "outboundDocTypes",
        "summaryAllowed"
      ],
      "limitsKeys": [],
      "capabilities": [
        "local-document"
      ]
    }
  ],
  "eventSchema": {
    "specVersion": "event-schema/v1",
    "eventTypes": [
      "plugin.execution.start",
      "workflow.node.start",
      "workflow.node.complete",
      "plugin.execution.complete",
      "plugin.execution.error"
    ],
    "requiredFields": [
      "eventId",
      "eventType",
      "occurredAt",
      "pluginId",
      "route",
      "nodeId"
    ]
  },
  "traceSchema": {
    "specVersion": "trace-schema/v1",
    "requiredSections": [
      "plugin",
      "workflow",
      "events",
      "timing",
      "result"
    ],
    "compatibility": [
      "searchTraceSummary",
      "executionContext"
    ]
  },
  "outputBinding": {
    "nodeId": "search-main",
    "path": "$"
  }
}
